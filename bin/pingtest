#!/bin/bash
RED='\033[0;31m'
NC='\033[0m'
while true; do
	clear

	echo "----------------------PING--TEST----------------------"
	echo -n "Press enter to begin"
	read
	echo -en "\e[1A"
	echo "                    "
	echo -en "\e[1A"

	while ! ping -c1 $1 &>/dev/null; do
		echo -e "${RED}`date +%r` - Failed${NC}" 
		sleep 1
	done

	echo "`date +%r` - Connected!"
	echo -e "`date +%r` - (testing the connection, please wait...)\n"
	/usr/bin/speedtest-cli --simple
	echo -e "\n`date +%r` - done"

	echo
	echo "------------------------------------------------------"
	echo -e "${RED}(download speeds should be between 5.00/10.00 Mbit/s)${NC}"
	echo -n "Press enter/return to run again"
	read
done
