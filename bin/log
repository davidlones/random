#!/usr/bin/env python3
# _0853RV3R
import argparse, logging, traceback

logfile = '/home/davidlones/logs/personal.log'
parser = argparse.ArgumentParser()

logger = logging.getLogger(__name__)
hdlr = logging.FileHandler(logfile)
formatter = logging.Formatter('%(asctime)s %(levelname)s %(message)s')
hdlr.setFormatter(formatter)
logger.addHandler(hdlr)
logger.setLevel(logging.DEBUG)

parser.add_argument('entry', action='store', nargs='?', default=False)
parser.add_argument('-d', '--debug', action='store_true', dest='debug')
parser.add_argument('-i', '--info', action='store_true', dest='info')
parser.add_argument('-w', '--warning', action='store_true', dest='warning')
parser.add_argument('-e', '--error', action="store_true", dest='error')
parser.add_argument('-c', '--critical', action='store_true', dest='critical')
parser.add_argument('-r', '--read', action='store_true', dest='read')
parser.add_argument('-p', '--print', action='store_true', dest='show')

argument = parser.parse_args()

if argument.entry:
	if argument.debug:
		logger.debug(argument.entry)
	elif argument.info:
		logger.info(argument.entry)
	elif argument.warning:
		logger.warning(argument.entry)
	elif argument.error:
		logger.error(argument.entry)
	elif argument.critical:
		logger.critical(argument.entry)
	else:
		logger.info(argument.entry)
else:
	argument.read = True


fileHandle = open ( logfile,"r" )
lineList = fileHandle.readlines()
fileHandle.close()

if argument.read:
	for line in lineList:
		print(line, end = '')
if argument.show:
	print(str(len(lineList)) + ': ' + lineList[-1], end = '')
