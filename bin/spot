#!/bin/bash
# _0853RV3R

# dbus_session_file=~/.dbus/session-bus/$(cat /var/lib/dbus/machine-id)-0
# if [ -e "$dbus_session_file" ]; then
#   . "$dbus_session_file"
#   export DBUS_SESSION_BUS_ADDRESS DBUS_SESSION_BUS_PID
# fi
export DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus

usrvar=$@

if [ "$usrvar" = "play" ]
    then dbus-send --print-reply --dest=org.mpris.MediaPlayer2.spotify /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Player.Play

elif [ "$usrvar" = "pause" ]
    then dbus-send --print-reply --dest=org.mpris.MediaPlayer2.spotify /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Player.Pause

else
	dbus-send --print-reply --dest=org.mpris.MediaPlayer2.spotify /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Player.OpenUri string:$usrvar
fi
